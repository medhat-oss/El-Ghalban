// ============================================================
// El-Ghalban | الغلبان — Prisma Schema (Optimized)
// Provider: PostgreSQL (Neon / Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Category Model
// ─────────────────────────────────────────────
model Category {
  id        String    @id @default(cuid())
  name      String    // English name (internal)
  nameAr    String    // Arabic display name
  slug      String    @unique // e.g. "mobiles", "accessories"
  icon      String?   // Optional emoji / icon identifier
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

// ─────────────────────────────────────────────
// Product Model
// ─────────────────────────────────────────────
model Product {
  id            String      @id @default(cuid())
  name          String      // English name
  nameAr        String      // Arabic display name
  description   String?     @db.Text // وصف طويل
  descriptionAr String?     @db.Text
  price         Float       // Price in EGP
  oldPrice      Float?      // Original price before discount
  images        ProductImage[] // Changed from String[] to relation
  isAvailable   Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  stock         Int         @default(0)
  brand         String?     // e.g. "Samsung"
  model         String?     // e.g. "Galaxy S24"
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  // علاقة مع تفاصيل الطلبات لتحليل المبيعات مستقبلاً
  orderItems    OrderItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Indexes محسنّة للبحث والفلترة
  @@index([categoryId])
  @@index([isAvailable, isFeatured])
  @@index([price])
  @@map("products")
}

// ─────────────────────────────────────────────
// ProductImage Model (جديد: لدعم تعدد الصور)
// ─────────────────────────────────────────────
model ProductImage {
  id        String   @id @default(cuid())
  url       String   // Cloudinary URL
  publicId  String?  // Cloudinary Public ID for deletion
  isMain    Boolean  @default(false)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────
// Order Model (المحسن للأداء)
// ─────────────────────────────────────────────
model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique @default(cuid()) 
  customerName    String
  phone           String
  address         String
  city            String?
  notes           String?       @db.Text
  
  // التفاصيل المحسنة للأوردر
  items           OrderItem[]   // علاقة مع جدول التفاصيل
  
  subtotal        Float
  deliveryFee     Float         @default(0)
  total           Float
  status          OrderStatus   @default(PENDING)
  paymentMethod   String        @default("CASH_ON_DELIVERY")
  sentViaWhatsApp Boolean       @default(false)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

// ─────────────────────────────────────────────
// OrderItem Model (جديد: لتنظيم محتويات السلة)
// ─────────────────────────────────────────────
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Float   // السعر وقت الشراء (عشان لو السعر اتغير في المتجر يفضل ثابت في الأوردر)
  
  @@map("order_items")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
