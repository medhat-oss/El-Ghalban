// ============================================================
// El-Ghalban | الغلبان — Prisma Schema
// Provider: PostgreSQL (Supabase / Neon compatible)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Category Model
// ─────────────────────────────────────────────
model Category {
  id        String    @id @default(cuid())
  name      String    // English name (internal)
  nameAr    String    // Arabic display name
  slug      String    @unique // e.g. "mobiles", "accessories"
  icon      String?   // Optional emoji / icon identifier
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

// ─────────────────────────────────────────────
// Product Model
// ─────────────────────────────────────────────
model Product {
  id            String   @id @default(cuid())
  name          String   // English name
  nameAr        String   // Arabic display name
  description   String?  // English description
  descriptionAr String?  // Arabic description
  price         Float    // Price in EGP (Egyptian Pounds)
  oldPrice      Float?   // Original price before discount
  images        String[] // Array of Cloudinary URLs
  isAvailable   Boolean  @default(true)  // Inventory availability flag
  isFeatured    Boolean  @default(false) // Show on homepage
  stock         Int      @default(0)     // Quantity in stock
  brand         String?  // e.g. "Samsung", "Apple"
  model         String?  // e.g. "Galaxy S24"
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Indexes for optimized querying
  @@index([categoryId])
  @@index([isAvailable])
  @@index([isFeatured])
  @@index([createdAt(sort: Desc)])
  @@index([price])
  @@map("products")
}

// ─────────────────────────────────────────────
// Order Model
// ─────────────────────────────────────────────
model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique @default(cuid()) // Human-readable ref
  customerName String
  phone        String
  address      String
  city         String?
  notes        String?
  items        Json        // Serialised cart snapshot
  subtotal     Float
  deliveryFee  Float       @default(0)
  total        Float
  status       OrderStatus @default(PENDING)
  paymentMethod String     @default("CASH_ON_DELIVERY")
  sentViaWhatsApp Boolean  @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
